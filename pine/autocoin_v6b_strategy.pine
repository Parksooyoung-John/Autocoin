//@version=5
// AutoCoin v6-B Donchian Experiment Strategy
// - Backtest-only strategy() script. Do not use this file for Demo/Live webhook alerts.
// - Experiments:
//   CURRENT: Donchian 40 / exit 20
//   A: Donchian 20 / exit 10
//   B: Donchian 30 / exit 15
// - Optional hybrid mode adds v5-style Range LONG entries.
strategy("AutoCoin v6-B Donchian Experiments", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.05, pyramiding=0, process_orders_on_close=true)

// === Experiment controls ===
experimentPreset = input.string("CURRENT_40_20", "Experiment Preset", options=["CURRENT_40_20", "A_20_10", "B_30_15", "CUSTOM"])
customDonchianLen = input.int(40, "Custom Donchian Entry Length", minval=2)
customExitLen = input.int(20, "Custom Exit Length", minval=2)
enableRangeLong = input.bool(false, "Enable Hybrid Range LONG")

donchianLen = experimentPreset == "A_20_10" ? 20 : experimentPreset == "B_30_15" ? 30 : experimentPreset == "CUSTOM" ? customDonchianLen : 40
exitLen = experimentPreset == "A_20_10" ? 10 : experimentPreset == "B_30_15" ? 15 : experimentPreset == "CUSTOM" ? customExitLen : 20

// === Shared inputs ===
btcFilterSymbol = input.symbol("BINANCE:BTCUSDT", "BTC Filter Symbol")
emaFastLen = input.int(20, "EMA Fast Length", minval=1)
emaMidLen = input.int(60, "EMA Mid Length", minval=1)
emaSlowLen = input.int(200, "EMA Slow Length", minval=1)
rsiLen = input.int(14, "RSI Length", minval=1)
atrLen = input.int(14, "ATR Length", minval=1)
atrSmaLen = input.int(20, "ATR SMA Length", minval=1)
atrStopMult = input.float(2.5, "ATR Stop Multiplier", minval=0.1, step=0.1)
abnormalAtrMult = input.float(3.0, "Abnormal ATR Filter", minval=1.0, step=0.1)
bbLen = input.int(20, "Range Bollinger Length", minval=1)
bbMult = input.float(2.0, "Range Bollinger Multiplier", minval=0.1, step=0.1)
bbNearPercent = input.float(1.0, "Range Band Nearness %", minval=0.1, step=0.1)

// === Indicators ===
ema20 = ta.ema(close, emaFastLen)
ema60 = ta.ema(close, emaMidLen)
ema200 = ta.ema(close, emaSlowLen)
rsi = ta.rsi(close, rsiLen)
atr = ta.atr(atrLen)
atrSma = ta.sma(atr, atrSmaLen)
bbBasis = ta.sma(close, bbLen)
bbDev = ta.stdev(close, bbLen) * bbMult
bbUpper = bbBasis + bbDev
bbLower = bbBasis - bbDev

// === BTC correlation filter, no lookahead ===
btcClose = request.security(btcFilterSymbol, timeframe.period, close, barmerge.gaps_off, barmerge.lookahead_off)
btcEma20 = request.security(btcFilterSymbol, timeframe.period, ta.ema(close, emaFastLen), barmerge.gaps_off, barmerge.lookahead_off)
isBtcChart = str.contains(syminfo.ticker, "BTCUSDT")
btcLongAllowed = isBtcChart ? true : btcClose > btcEma20

// === Regime helper for optional hybrid Range LONG ===
emaBullAligned = ema20 > ema60 and ema60 > ema200
emaBearAligned = ema20 < ema60 and ema60 < ema200
rangeRegime = not emaBullAligned and not emaBearAligned
nearLowerBand = close <= bbLower * (1 + bbNearPercent / 100)

// === Shared filters and state ===
abnormalVolatility = atr > atrSma * abnormalAtrMult
flat = strategy.position_size == 0
longPosition = strategy.position_size > 0
canEnter = barstate.isconfirmed and flat and not abnormalVolatility and btcLongAllowed

var float activeStop = na
var float entryAtr = na
var string entryPath = ""

// === Entry paths ===
donchianBreakout = close > ta.highest(high, donchianLen)[1]
donchianLongSignal = canEnter and close > ema200 and donchianBreakout
rangeLongSignal = canEnter and enableRangeLong and rangeRegime and rsi < 35 and nearLowerBand

if donchianLongSignal or rangeLongSignal
    entryAtr := atr
    activeStop := math.max(ta.lowest(low, exitLen), close - entryAtr * atrStopMult)
    entryPath := donchianLongSignal ? "DONCHIAN" : "RANGE_LONG"
    strategy.entry("V6B_LONG", strategy.long, comment="V6B_LONG")

// === Trailing stop ===
if barstate.isconfirmed and longPosition and not na(entryAtr)
    fixedAtrStop = strategy.position_avg_price - entryAtr * atrStopMult
    channelStop = ta.lowest(low, exitLen)
    activeStop := math.max(activeStop, channelStop, fixedAtrStop)

exitSignal = barstate.isconfirmed and longPosition and not na(activeStop) and close < activeStop

if exitSignal
    strategy.close("V6B_LONG", comment="V6B_LONG_EXIT")
    activeStop := na
    entryAtr := na
    entryPath := ""

if barstate.isconfirmed and flat and strategy.position_size[1] != 0
    activeStop := na
    entryAtr := na
    entryPath := ""

// === Visuals ===
plot(ema20, "EMA20", color=color.yellow)
plot(ema60, "EMA60", color=color.orange)
plot(ema200, "EMA200", color=color.red)
plot(ta.highest(high, donchianLen)[1], "Donchian Entry High", color=color.new(color.lime, 0))
plot(ta.lowest(low, exitLen), "Exit Channel Low", color=color.new(color.red, 20))
plot(activeStop, "Active Stop", color=color.white, style=plot.style_linebr, linewidth=2)
plot(bbUpper, "Range BB Upper", color=color.new(color.blue, 80))
plot(bbBasis, "Range BB Basis", color=color.new(color.blue, 85))
plot(bbLower, "Range BB Lower", color=color.new(color.blue, 80))

plotshape(donchianLongSignal, "Donchian Entry", shape.triangleup, location.belowbar, color=color.lime, size=size.small, text="D")
plotshape(rangeLongSignal, "Range Entry", shape.triangleup, location.belowbar, color=color.aqua, size=size.small, text="R")
plotshape(exitSignal, "Exit", shape.triangledown, location.abovebar, color=color.red, size=size.small, text="X")

var table statsTable = table.new(position.top_right, 2, 7, border_width=1)
if barstate.islast
    winRate = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0.0
    profitFactor = strategy.grossloss != 0 ? strategy.grossprofit / math.abs(strategy.grossloss) : na
    table.cell(statsTable, 0, 0, "Preset", text_color=color.white)
    table.cell(statsTable, 1, 0, experimentPreset, text_color=color.white)
    table.cell(statsTable, 0, 1, "Lens", text_color=color.white)
    table.cell(statsTable, 1, 1, str.tostring(donchianLen) + "/" + str.tostring(exitLen), text_color=color.white)
    table.cell(statsTable, 0, 2, "Hybrid", text_color=color.white)
    table.cell(statsTable, 1, 2, enableRangeLong ? "ON" : "OFF", text_color=color.white)
    table.cell(statsTable, 0, 3, "Win Rate", text_color=color.white)
    table.cell(statsTable, 1, 3, str.tostring(winRate, "#.##") + "%", text_color=color.white)
    table.cell(statsTable, 0, 4, "Profit Factor", text_color=color.white)
    table.cell(statsTable, 1, 4, na(profitFactor) ? "n/a" : str.tostring(profitFactor, "#.##"), text_color=color.white)
    table.cell(statsTable, 0, 5, "Closed Trades", text_color=color.white)
    table.cell(statsTable, 1, 5, str.tostring(strategy.closedtrades), text_color=color.white)
    table.cell(statsTable, 0, 6, "Active Stop", text_color=color.white)
    table.cell(statsTable, 1, 6, na(activeStop) ? "n/a" : str.tostring(activeStop, format.mintick), text_color=color.white)
